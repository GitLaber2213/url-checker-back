# Скопируйте на сервере: cp .env.production.example .env
# Локально для docker compose: cp .env.production.example .env (override подставит dev-пароли для postgres)

POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=3205-test

# URL фронтенда (CORS). Пример: http://201.51.8.123 или https://your-domain.com
CORS_ORIGIN=http://201.51.8.123
