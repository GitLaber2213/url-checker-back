# Скопируйте на сервере: cp .env.production.example .env
# Только эти переменные — DATABASE_URL и REDIS_* задаёт docker-compose.yml

POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=3205-test

# URL фронтенда (CORS). Пример: http://201.51.8.123 или https://your-domain.com
CORS_ORIGIN=http://201.51.8.123

# Если после смены POSTGRES_PASSWORD backend падает с P1000, один раз на сервере:
# RESET_DB=1 ./scripts/deploy.sh
